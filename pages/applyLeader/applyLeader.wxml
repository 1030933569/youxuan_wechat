<view class="page">
  <view class="form">
    <view class="form-item">
      <text class="label">提货点名称</text>
      <input class="input" placeholder="请输入提货点名称" value="{{takeName}}" bindinput="onTakeNameInput"></input>
    </view>

    <view class="form-item">
      <text class="label">详细地址</text>
      <input class="input" placeholder="请输入详细地址" value="{{detailAddress}}" bindinput="onDetailAddressInput"></input>
    </view>

    <view class="location-info">
      <text class="label">当前位置</text>
      <text class="value" wx:if="{{latitude && longitude}}">{{latitude}}, {{longitude}}</text>
      <text class="value" wx:else>获取中...</text>
    </view>

    <button class="submit-btn" type="primary" bindtap="onSubmit" loading="{{loading}}">提交开团申请</button>
  </view>
</view>
