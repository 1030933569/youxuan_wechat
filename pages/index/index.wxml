<view class="page">
  <!-- 提货点区域 -->
  <view class="pickup card" bindtap="onPickupTap">
    <text class="label">提货点</text>
    <text class="name">{{leaderAddressVo.takeName || '未选择提货点'}}</text>
    <text class="arrow">></text>
  </view>

  <!-- 开团按钮 - 未选择提货点时显示 -->
  <view class="apply-leader-section" wx:if="{{!leaderAddressVo.leaderId}}">
    <button class="apply-btn" bindtap="onApplyLeaderTap">申请成为团长</button>
  </view>

  <scroll-view scroll-x class="category-sv" show-scrollbar="false">
    <view class="category-list">
      <view
        class="category-item {{selectedCategoryId === item.id ? 'active' : ''}}"
        wx:for="{{categoryList}}"
        wx:key="id"
        bindtap="onCategoryTap"
        data-id="{{item.id}}"
        data-name="{{item.name}}"
      >
        <image class="category-img" src="{{item.imgUrl}}" mode="aspectFill"></image>
        <text class="category-name">{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <view class="section-title">热销好货</view>
  <view class="product-list">
    <product-item wx:for="{{hotSkuList}}" wx:key="id" item="{{item}}" bind:tap="onProductTap" bind:add="onAddToCart"></product-item>
  </view>
</view>

